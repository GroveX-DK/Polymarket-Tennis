# Copy this file to pi_bot/.env and fill in your values.
# pi_bot/.env is gitignored - NEVER commit the real file.

# paper (default, no keys needed) or live (real money!)
TRADE_MODE=paper

# --- only needed when TRADE_MODE=live ---
# Polygon private key that signs orders. This key controls funds - treat it
# like a password. Export it from your wallet, or from Polymarket:
# profile -> settings -> export private key (email/Magic accounts).
POLYMARKET_PRIVATE_KEY=

# Your Polymarket deposit/proxy address (shown on the deposit page, holds the
# USDC). Leave empty only if you trade straight from the key's own address.
POLYMARKET_FUNDER=

# How the key relates to the funder: 1 = email/Magic login, 2 = browser
# wallet (MetaMask etc.), 0 = raw EOA (no proxy). Default 2 when FUNDER set.
POLYMARKET_SIGNATURE_TYPE=

# USDC per trade (min ~$5 so orders clear the $1 minimum at 0.80-0.97 prices)
STAKE_USDC=5

# Safety cap: no new live orders while this many live positions are open
MAX_OPEN_TRADES=10
